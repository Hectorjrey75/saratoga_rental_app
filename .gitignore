# ============================================
# PROJECT SPECIFIC - DATA
# ============================================
# Datos procesados (generados automáticamente)
data/processed/*.csv
data/processed/*.json
data/processed/*.pkl

# Modelos entrenados (archivos grandes)
data/models/*.pkl
data/models/*.joblib
data/models/*.h5
data/models/*.pb
data/models/*.json
data/models/*.txt

# Mantener los directorios pero no su contenido
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/models/.gitkeep

# Datos crudos (si son muy grandes, mejor no subirlos)
# Si el dataset es >100MB, descomenta la siguiente línea:
# data/raw/*.csv
# !data/raw/.gitkeep

# ============================================
# PROJECT SPECIFIC - LOGS
# ============================================
logs/*.log
logs/*.log.*
logs/*.zip
logs/*.gz
!logs/.gitkeep

# ============================================
# PROJECT SPECIFIC - STREAMLIT
# ============================================
.streamlit/secrets.toml
.streamlit/config.toml

# ============================================
# PROJECT SPECIFIC - OUTPUTS
# ============================================
outputs/
exports/
reports/
figures/
*.html
*.pdf

